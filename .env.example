# ── 通知通道开关 ──
# 可选值: email | feishu | all （默认 feishu）
NOTIFY_CHANNEL=feishu

# ── 飞书配置（二选一）──
#
# 方式一（推荐）: Webhook —— 只需一个 URL，无需 app 凭证
# 操作：飞书群 → 设置 → 群机器人 → 添加机器人 → 自定义机器人 → 复制 Webhook 地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 签名校验密钥（如果创建机器人时启用了"签名校验"则必填）
FEISHU_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxx
#
# 方式二: App API —— 需要自建应用凭证 + 接收方 ID
# FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# FEISHU_RECEIVE_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=chat_id

# ── 邮件配置（当 NOTIFY_CHANNEL 为 email 或 all 时使用）──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
GMAIL_USERNAME=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_TO=recipient1@example.com,recipient2@example.com
